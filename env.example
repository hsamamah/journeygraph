# .env.example
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password

# ── WMATA ─────────────────────────────────────────────────────────────────────
WMATA_API_KEY=your_wmata_api_key

# Optional — override the default GTFS feed URL
# GTFS_FEED_URL=https://api.wmata.com/gtfs/rail-bus-gtfs-static.zip

# ── LLM pipeline (required only for src/llm/) ─────────────────────────────────
# Install with: uv sync --extra llm
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional LLM overrides — defaults shown
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_MAX_TOKENS=512
